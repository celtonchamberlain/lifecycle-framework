# {{PROJECT_NAME}} — project-local secrets (GITIGNORED — NEVER COMMIT THIS FILE).
# Scaffolded by /lifecycle-init on {{TODAY}}. This is a STUB: fill in the real
# values locally. The committed .gitignore excludes .claude/.local/ entirely, so
# nothing here reaches git. Rule: credentials NEVER live in committed files
# (settings.json, corpus.config.mjs, CLAUDE.md) — only here.
#
# Tracker for this project: {{TRACKER}}   Stack: {{STACK}}   Databricks: {{DATABRICKS}}
# Connection IDENTITY (git remote/branch, tracker org/team/project/key/cloud-id,
# Databricks envs/profile/host+warehouse maps) lives in the COMMITTED
# .claude/settings.json + corpus.config.mjs. Only the TOKENS live here.

# === Tracker API token =====================================================
# This project's tracker is: {{TRACKER}}. Fill only the matching block below.
#
# Linear ({{TRACKER}} = linear): a personal API key
#   (Settings -> Security & access -> API). Identity is in settings.json:
#   org {{TRACKER_ORG}} / team {{TRACKER_TEAM}} / project {{TRACKER_PROJECT}} / key {{TRACKER_KEY}}.
LINEAR_API_KEY=
#
# Jira / Atlassian ({{TRACKER}} = jira): an API token
#   (id.atlassian.com -> Security -> API tokens), used with your account email
#   as HTTP Basic auth. Identity is in settings.json:
#   cloud-id {{TRACKER_CLOUD_ID}} / project key {{TRACKER_KEY}}.
JIRA_EMAIL=
JIRA_API_TOKEN=

# === GitHub token ==========================================================
# Fine-grained PAT scoped to {{GITHUB_REPO}} (repo + pull-request scopes).
# Used by the github MCP / gh CLI for PR operations on {{GIT_HOST}}
# (branch {{GIT_BRANCH}}, default {{GIT_DEFAULT_BRANCH}}).
GITHUB_TOKEN=

# === Databricks ============================================================
# Databricks for this project: {{DATABRICKS}} (envs: {{DATABRICKS_ENVS}};
# default profile: {{DATABRICKS_PROFILE}}; default host: {{DATABRICKS_DEFAULT_HOST}}).
# AUTH NOTE: do NOT put Databricks tokens here. Authenticate via the profiles in
# ~/.databrickscfg (the source of truth) using OAuth — w.config.authenticate() —
# and the databricks-sql-connector for local SQL. Hosts/warehouse ids are config,
# not secrets, and live in committed settings.json / corpus.config.mjs (never
# hardcoded in code). Only set a raw token below if you genuinely cannot use a
# ~/.databrickscfg profile.
# On Windows, force UTF-8 so Unicode output renders correctly:
PYTHONIOENCODING=utf-8

# === Per-project memory path ===============================================
# The persistent knowledge-graph file /close-task writes to. MUST be unique
# per project (named from the project slug) so memory never bleeds between
# projects. Do NOT point this at a plugin-shared data dir.
MEMORY_FILE_PATH={{MEMORY_FILE_PATH}}

