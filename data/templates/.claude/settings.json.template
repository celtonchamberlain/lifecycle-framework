{
  "$schema_note": "COMMITTED project settings for {{PROJECT_NAME}} ({{STACK}} stack, tracker={{TRACKER}}). Committed (NOT settings.local.json) so PM-spawned Agent-Teams teammates and CI inherit the Agent Teams flag, the scoped permission allowlist, and the destructive-command guard. Without this committed file, teammates block on permission prompts mid-lifecycle and the orchestration silently collapses to a single agent. Secrets (tracker token, GitHub token, Databricks token, memory path) live in the gitignored .claude/.local/secrets.env, never here. Generated by /lifecycle-init on {{TODAY}}.",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "PROJECT_TRACKER": "{{TRACKER}}",
    "PROJECT_TRACKER_ORG": "{{TRACKER_ORG}}",
    "PROJECT_TRACKER_TEAM": "{{TRACKER_TEAM}}",
    "PROJECT_TRACKER_PROJECT": "{{TRACKER_PROJECT}}",
    "PROJECT_TRACKER_KEY": "{{TRACKER_KEY}}",
    "PROJECT_TRACKER_CLOUD_ID": "{{TRACKER_CLOUD_ID}}",
    "PROJECT_STACK": "{{STACK}}"
  },

  "project": {
    "name": "{{PROJECT_NAME}}",
    "slug": "{{PROJECT_SLUG}}",
    "goal": "{{PROJECT_GOAL}}",
    "stack": "{{STACK}}",
    "communication": "{{COMM_LANGUAGE}}"
  },

  "tracker": {
    "type": "{{TRACKER}}",
    "org": "{{TRACKER_ORG}}",
    "team": "{{TRACKER_TEAM}}",
    "project": "{{TRACKER_PROJECT}}",
    "key": "{{TRACKER_KEY}}",
    "cloudId": "{{TRACKER_CLOUD_ID}}"
  },

  "git": {
    "repo": "{{GITHUB_REPO}}",
    "host": "{{GIT_HOST}}",
    "branch": "{{GIT_BRANCH}}",
    "defaultBranch": "{{GIT_DEFAULT_BRANCH}}"
  },

  "databricks": {
    "enabled": "{{DATABRICKS}}",
    "envs": "{{DATABRICKS_ENVS}}",
    "profile": "{{DATABRICKS_PROFILE}}",
    "defaultHost": "{{DATABRICKS_DEFAULT_HOST}}",
    "hosts": {{DATABRICKS_HOSTS_JSON}},
    "warehouses": {{DATABRICKS_WAREHOUSES_JSON}}
  },

  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",

      "Bash(node *)",
      "Bash(node -e:*)",
      "Bash(node -p:*)",
      "Bash(npm view:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm audit:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git remote:*)",
      "Bash(git show-ref:*)",
      "Bash(git blame:*)",

      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(test:*)",
      "Bash(cat package.json)",
      "Bash(cat package-lock.json)",
      "Bash(cat tsconfig.json)",

      "Write(docs/claude_tasks/reviews/**)",
      "Write(docs/claude_tasks/reports/**)",
      "Write(docs/claude_tasks/council/**)",
      "Write(docs/claude_tasks/alpha_tests/**)",
      "Write(docs/audits/**)",
      "Write(docs/**)",
      "Edit(docs/**)",
      "Write(src/**)",
      "Edit(src/**)",
      "Write(tests/**)",
      "Edit(tests/**)",
      "Write(scripts/**)",
      "Edit(scripts/**)",

      "mcp__memory__read_graph",
      "mcp__memory__search_nodes",
      "mcp__memory__open_nodes",
      "mcp__memory__create_entities",
      "mcp__memory__add_observations",
      "mcp__memory__create_relations",

      "mcp__claude_ai_Linear__get_issue",
      "mcp__claude_ai_Linear__list_issues",
      "mcp__claude_ai_Linear__list_comments",
      "mcp__claude_ai_Linear__get_team",
      "mcp__claude_ai_Linear__list_issue_labels",
      "mcp__claude_ai_Linear__save_comment",
      "mcp__claude_ai_Linear__save_issue",

      "mcp__claude_ai_Atlassian__getJiraIssue",
      "mcp__claude_ai_Atlassian__searchJiraIssuesUsingJql",
      "mcp__claude_ai_Atlassian__addCommentToJiraIssue",
      "mcp__claude_ai_Atlassian__editJiraIssue",
      "mcp__claude_ai_Atlassian__getTransitionsForJiraIssue",
      "mcp__claude_ai_Atlassian__transitionJiraIssue",
      "mcp__claude_ai_Atlassian__getAccessibleAtlassianResources",

      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Read(.claude/.local/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },

  "enabledMcpjsonServers": [
    "memory"
  ],
  "enableAllProjectMcpServers": true,

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/check_destructive.py\""
          }
        ]
      }
    ]
  }
}
