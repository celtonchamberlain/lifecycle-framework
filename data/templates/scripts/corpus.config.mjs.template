/**
 * The repo this framework runs in. `branch` is the working branch captured at
 * scaffold time (1 ticket = 1 branch = 1 PR); `defaultBranch` is the PR base
 * (main/master); `repo` is the origin URL. GITHUB_TOKEN, if any, lives in
 * .claude/.local/secrets.env â€” never here.
 */
export const git = {
  branch: '{{GIT_BRANCH}}',
  defaultBranch: '{{GIT_DEFAULT_BRANCH}}',
  repo: '{{GITHUB_REPO}}',
};

// ---------------------------------------------------------------------------
// Databricks connection (committed config â€” no secrets)
// ---------------------------------------------------------------------------

/**
 * Databricks wiring for the data stack. NON-SECRET configuration only:
 *   enabled       on/off (string) â€” gate; when 'off', the maps are empty.
 *   envs          environments in use, comma list (e.g. 'dev,qa,prod').
 *   profile       default ~/.databrickscfg profile/env for everyday work.
 *   defaultHost   workspace URL for the default profile.
 *   hosts         per-env workspace URL map  ({"dev":"https://...", ...}).
 *   warehouses    per-env SQL warehouse id map ({"dev":"abc123", ...}).
 *
 * Hosts and warehouse ids are configuration, not secrets, but per the data-stack
 * rules they must NOT be hardcoded inside scripts â€” they are read from
 * here. Local SQL uses databricks-sql-connector; auth is OAuth via
 * w.config.authenticate() (never raw tokens); on Windows set
 * PYTHONIOENCODING=utf-8 (in .claude/.local/secrets.env). ~/.databrickscfg is
 * the source of truth for profiles/hosts.
 */
export const databricks = {
  enabled: '{{DATABRICKS}}',
  envs: '{{DATABRICKS_ENVS}}',
  profile: '{{DATABRICKS_PROFILE}}',
  defaultHost: '{{DATABRICKS_DEFAULT_HOST}}',
  hosts: {{DATABRICKS_HOSTS_JSON}},
  warehouses: {{DATABRICKS_WAREHOUSES_JSON}},
};

