#!/usr/bin/env sh
# pre-push: rebuild the corpus INDEX and BLOCK the push if it drifts from source.
# Keeps docs/INDEX.md + docs/index.json provably in sync with the governed corpus
# before anything leaves the machine (CI re-verifies the same invariant).
# Invoked by repo-relative path (no ${CLAUDE_PLUGIN_ROOT} in git hooks).

# Abort the hook immediately if build-index.mjs exits non-zero (e.g. timeout, uncaught error).
set -e

node scripts/build-index.mjs

if ! git diff --quiet docs/INDEX.md docs/index.json; then
  echo ""
  echo "ERROR: INDEX drift — docs/INDEX.md or docs/index.json is out of sync with source."
  echo ""
  echo "Fix:  npm run build:index && git add docs/INDEX.md docs/index.json"
  echo "      git commit --amend --no-edit  # or new commit"
  echo "      git push"
  echo ""
  echo "Skip (emergencies only):  git push --no-verify"
  exit 1
fi
