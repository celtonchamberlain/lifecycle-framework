/**
 * corpus.config.mjs â€” Single source of truth for {{PROJECT_NAME}} corpus constants.
 *
 * Scaffolded by /lifecycle-init from the lifecycle-framework plugin. The five
 * corpus tools import their project-specific constants from this module:
 *   - _corpus-walk.mjs          (EXCLUDED_DIRS, EXCLUDED_ROOT_FILES, PROJECT_SKILLS)
 *   - validate-frontmatter.mjs  (TYPE/STATUS/AUTHORITY enums, verdicts, affects grammar, VALIDATOR)
 *   - build-index.mjs           (TICKET_REGEX, OUTPUT paths)
 *   - log-commit-activity.mjs   (OUTPUT paths, BRANCH_TICKET_REGEX, TICKET_KEY)
 *   - affects-lookup.mjs        (TICKET_REGEX, OUTPUT paths)
 *
 * Change the taxonomy in ONE place; the tools follow. Centralizing these
 * constants eliminates the multi-file drift that comes from each script
 * inlining its own copy of the enums/exclusions.
 *
 * Taxonomy authority: .claude/rules/frontmatter.md (the frontmatter SSOT).
 *
 * Project identity, tracker, git, and Databricks connection details are the
 * committed (NON-SECRET) half of the project's wiring â€” they mirror
 * .claude/settings.json. Secrets (API tokens, PYTHONIOENCODING) live ONLY in
 * the gitignored .claude/.local/secrets.env; never hardcode credentials,
 * catalog names, or workspace URLs in code. Databricks hosts/warehouse ids
 * below are configuration, not secrets, and per the data-stack rules must
 * live here in config rather than inline in any script.
 *
 * Tracker key for this project: {{TRACKER_KEY}}   (e.g. CRI, ABC, PROJ).
 * If tracker = none, {{TRACKER_KEY}} is still set to a local prefix used only
 * for branch/filename derivation; tickets remain optional in frontmatter.
 */

// ---------------------------------------------------------------------------
// Project identity
// ---------------------------------------------------------------------------

/** Stable project slug â€” names the per-project memory file; unique per project. */
export const projectSlug = '{{PROJECT_SLUG}}';

/** The project's tracker ticket prefix (Jira project key or Linear prefix). */
export const ticketKey = '{{TRACKER_KEY}}';

/**
 * Tracker (issue-tracking) connection â€” committed identity only, no token.
 *   type      'linear' | 'jira' | 'none'
 *   key       ticket prefix / Jira project key (= ticketKey)
 *   org       Linear workspace (empty for Jira)
 *   team      Linear team (empty unless team-managed)
 *   project   Linear project/initiative id-or-name, or Jira project key
 *   cloudId   Atlassian site/cloud id (Jira only; empty for Linear)
 */
export const tracker = {
  type: '{{TRACKER}}',
  key: ticketKey,
  org: '{{TRACKER_ORG}}',
  team: '{{TRACKER_TEAM}}',
  project: '{{TRACKER_PROJECT}}',
  cloudId: '{{TRACKER_CLOUD_ID}}',
};

