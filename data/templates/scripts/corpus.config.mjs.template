export const ALPHA_TEST_STATUS_ENUM = new Set(['draft', 'sealed', 'passed', 'failed']);

// ---------------------------------------------------------------------------
// Ticket identifiers (tracker key = {{TRACKER_KEY}})
// ---------------------------------------------------------------------------

/**
 * The project's tracker ticket prefix (Jira project key or Linear ticket
 * prefix). Drives both TICKET_REGEX (frontmatter full-string match) and
 * BRANCH_TICKET_REGEX (loose derivation from branch names / filenames).
 * Alias of `ticketKey`, kept for the historical import surface
 * (log-commit-activity.mjs imports TICKET_KEY).
 */
export const TICKET_KEY = ticketKey;

/**
 * Canonical ticket format â€” full-string match for the frontmatter `ticket`
 * field plus `depends_on` / `supersedes`. Example: {{TRACKER_KEY}}-123.
 */
export const TICKET_REGEX = new RegExp(`^${TICKET_KEY}-\\d+$`);

/**
 * Loose derivation variant â€” extracts the ticket number from branch names
 * (feat/{{TRACKER_KEY}}-912-slug, user/{{TRACKER_KEY}}-912-slug) and filenames
 * ({{TRACKER_KEY}}-912_foo.md). Capture group 1 is the numeric part; normalize
 * to `${TICKET_KEY}-${m[1]}`. Case-insensitive so lowercase branch slugs match.
 */
export const BRANCH_TICKET_REGEX = new RegExp(`${TICKET_KEY}-?(\\d+)`, 'i');

// ---------------------------------------------------------------------------
// affects: prefix grammar
// ---------------------------------------------------------------------------

/**
 * Stack-neutral affects: grammar â€” the dotted namespaces a governed doc may
 * declare it affects. Extend this list per project (add stack-specific
 * namespaces such as table.* / metric.* for data projects, or route.* /
 * component.* for web projects). The validator (R8) enforces it.
 *
 *   module.<name>     a code module / package / service
 *   data.<name>       a dataset / table / model / store
 *   interface.<name>  an external interface / endpoint / API surface
 *   repo.<section>    a section of this repository
 *   env.<var>         an environment variable / runtime config key
 *   dep.<package>     a third-party dependency
 *   doc.<path-slug>   a governed document
 */
export const AFFECTS_PREFIXES = [
  'module.', 'data.', 'interface.',
  'repo.', 'env.', 'dep.', 'doc.',
];

export const AFFECTS_PREFIX_RE = new RegExp(
  `^(${AFFECTS_PREFIXES.map((p) => p.replace(/\./g, '\\.')).join('|')})`
);

// ---------------------------------------------------------------------------
// Corpus walk exclusions
// ---------------------------------------------------------------------------

/**
 * Directory basenames excluded from the corpus walk anywhere in the path.
 * Build outputs, vendored packages, tooling caches, and the _templates dir
 * (its placeholder values intentionally fail validation).
 */
export const EXCLUDED_DIRS = new Set([
  // Build outputs / vendored
  'node_modules', '.git', '.husky', 'out', 'coverage', 'dist', 'build',
  '.next', '.vercel', '.svelte-kit',
  // Tooling caches
  '__pycache__', '.venv', 'venv', '.pytest_cache', '.mypy_cache', '.ruff_cache',
  '.ipynb_checkpoints',
  // External / cache / editor dirs (not part of the governed corpus)
  '.agents', '.firecrawl', '.vs', '.idea', '.vscode', '.cache',
  // Templates use placeholder values that intentionally fail validation
  '_templates',
]);

/**
 * Root-level files that are human-owned working documents, not governed
 * corpus. They carry no frontmatter and must never be flagged by the validator.
 *   TODO.md   â€” the roadmap / tracker mirror (protected; human-owned).
 *   README.md â€” repo-facing prose for humans landing on the repository.
 */
export const EXCLUDED_ROOT_FILES = new Set([
  'TODO.md',
  'README.md',
]);

/**
 * Project-owned Claude Code skills (`.claude/skills/<name>/SKILL.md`) that ARE
 * part of the governed corpus. Any other depth >= 4 file under .claude/skills/
 * is excluded (vendored skill bundles, assets, references). NOTE: the
 * lifecycle-framework slash commands (/close-task, /log-activity, etc.) are
 * PLUGIN-RESIDENT and live outside this repo, so they are not listed here.
 * List only skills authored inside this project's `.claude/skills/`.
 */
export const PROJECT_SKILLS = new Set([
  // e.g. 'my-project-skill',
]);

